# .continueignore — HostingArena Token Reduction
# Goal: reduce active LLM context window by ~40%

# ── Build & Dependencies ────────────────────────────────────────
node_modules/
.next/
dist/
build/
out/
.turbo/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Generated / Bundle Artifacts ────────────────────────────────
frontend/public/video-bundle/
frontend/public/voices/previews/
frontend/.antigravityignore

# ── Large Static Data (fetched at runtime, not needed for coding)
frontend/public/data/*.json
data/verified_data.json
data/migrations/
supabase/migrations/

# ── Scrapers (irrelevant during frontend/video work) ─────────────
scrapers/
venv/
__pycache__/
*.pyc
requirements.txt

# ── Binary & Media Assets ────────────────────────────────────────
*.svg
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.mp3
*.wav
*.webm
*.ogg
*.ico
*.woff
*.woff2
*.ttf
*.eot

# ── Secrets & Environment ────────────────────────────────────────
.env
.env.*
.env.local
.env.production
service_account.json
*.pem
*.key

# ── IDE & Tool Configs (not code-relevant) ─────────────────────
.agent/
.cursor/
.continue/
.vscode/settings.json
.idea/
*.iml

# ── Next.js / Vercel Infra (rarely read during coding) ──────────
frontend/.vercel/
frontend/vercel.json
frontend/next-env.d.ts

# ── Lock / Hash Files ────────────────────────────────────────────
*.lock
*.tsbuildinfo

# ── Test Snapshots & Coverage ────────────────────────────────────
__snapshots__/
coverage/
.nyc_output/

# ── Git Internal ──────────────────────────────────────────────────
.git/

